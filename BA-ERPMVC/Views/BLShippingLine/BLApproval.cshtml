@model IEnumerable<BA_ERPMVC.ViewModels.BLApprovalViewModel>
<link rel="stylesheet" href="~/AdminLte/dist/css/styles.css" />


@{
    if (Session["UserName"] == null)
    {
        Response.Redirect("~/Account/Login");
    }
    ViewBag.Title = "Expenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<div id="gridShow" class="card">
    <div class="card-header" style="background:white;">
        <div class="row" style="margin-bottom:10px">
            <div class="col-sm-6 float-sm-left">
                <h4>BL Approval</h4>
            </div><!-- /.col -->

        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-lg-10 col-md-9 col-sm-12 col-xs-12 table-responsive center">
                <table id="example" class="table table-sm table-bordered mb-3 w-min-80 datatable h-auto d-inline-block w-auto">
                    <thead class="thead-light ">
                        <tr>
                            <th>BLNo#</th>
                            <th>ContainerNo#</th>
                            <th>SealNo#</th>
                            <th>Approval</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                       
                        <tr class="bg-light tbl-valign-top">
                            <td>
                                <input type="hidden" value="" class="form-control txt_ID" />
                                <input type="text" disabled style="width: 200px;" value="" class="form-control  txt_BLnumber" />
                            </td>
                            <td>
                                <input type="text" disabled style="width: 200px;" value="" class="form-control  txt_ContainerNo" />
                            </td>
                            <td>
                                <input type="text" style="width: 200px;" value="" class="form-control  txt_SealNo" />
                            </td>
                            <td>
                                <select id="txt_approval" class="form-control form-control-v1 form-control-sm border-dark mt-1 mb-0 txt_approval" style="width: 200px;">
                                    <option value="">Approval</option>
                                    <option value="ACCEPTED">ACCEPTED</option>
                                    <option value="REJECTED">REJECTED</option>
                                </select>
                            </td>

                            <td class="btn-group">
                                <button type="button" class="btn btn-sm btn-block btn-success btn-v2 fs-8 text-nowrap mt-1 mb-0 btnSaveEdit">Save/Update</button>&ensp;
                                <button type="button" class="btn btn-sm btn-block btn-danger btn-v2 fs-8 text-nowrap mt-1 mb-0 btndlt">Delete</button>
                            </td>
                        </tr>
                        
                            @foreach (var Bl in Model.ToList())
                            {
                                <tr class="bg-light tbl-valign-top">
                                    <td>
                                        <input type="hidden" value="@Bl.ID" class="form-control txt_ID" />

                                        <input type="text" disabled style="width: 200px;" value="@Bl.BLnumber" class="form-control  txt_BLnumber" />
                                    </td>
                                    <td>
                                        <input type="text" disabled style="width: 200px;" value="@Bl.ContainerNo" class="form-control  txt_ContainerNo" />
                                    </td>
                                    <td>
                                        <input type="text" disabled style="width: 200px;" value="@Bl.SealNo" class="form-control  txt_SealNo" />
                                    </td>

                                    <td>
                                        <select id="txt_approval" class="form-control form-control-v1 form-control-sm border-dark mt-1 mb-0 txt_approval" style="width: 100px;">
                                            <option value="">Approval</option>
                                            <option value="ACCEPTED">ACCEPTED</option>
                                            <option value="REJECTED">REJECTED</option>
                                        </select>
                                    </td>

                                    <td class="btn-group">
                                        <button type="button" class="btn btn-sm btn-block btn-success btn-v2 fs-8 text-nowrap mt-1 mb-0 btnSaveEdit">Save/Update</button>&ensp;
                                        <button type="button" class="btn btn-sm btn-block btn-danger btn-v2 fs-8 text-nowrap mt-1 mb-0 btndlt">Delete</button>
                                    </td>
                                </tr>
                            }

                        </tbody>
                </table>
            </div>
        </div>
        <!-- LOADING SHOW HIDE -->
        <div class="loading-dimmer"><img src="~/AdminLte/dist/img/loading.gif" /></div>
    </div>
   

    <script src="@Fingerprint.Tag("/AdminLte/Scripts/BLApproval.js")"></script>
