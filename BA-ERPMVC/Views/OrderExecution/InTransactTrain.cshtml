@model IEnumerable<BA_ERPMVC.ViewModels.OrderBooking.InTransactTrainViewModel>
<link rel="stylesheet" href="~/AdminLte/dist/css/styles.css" />
@{
    if (Session["UserName"] == null)
    {
        Response.Redirect("~/Account/Login");
    }
    ViewBag.Title = "Expenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<div id="gridShow" class="card">
    <div class="card-header" style="background:white;">
        <div class="row" style="margin-bottom:10px">
            <div class="col-sm-6 float-sm-left">
                <h4> InTransact Train</h4>
            </div><!-- /.col -->

        </div>


    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 table-responsive">
                <table id="tbl_Logistics" class="table table-sm table-bordered mb-3 w-min-100">
                    <thead class="thead-light">
                        <tr>
                            <th>Booking No#</th>
                            <th>Container No#</th>
                            <th>Container Size</th>
                            <th>ClientName</th>
                            <th>Priority For Dispatch</th>
                            <th>ArrivalDate</th>
                            <th>LOLO</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inTransactTrain in Model.ToList())
                        {
                        <tr class="bg-light tbl-valign-top">
                            <td>
                                <input type="hidden" value="@inTransactTrain.OrderId" class="form-control txt_OrderId" />
                                <input type="hidden" value="@inTransactTrain.BLnumber" class="form-control txt_BLnumber" />
                                <input type="hidden" value="@Convert.ToInt32(inTransactTrain.ID)" class="form-control txt_ID" />
                                <input type="text" class="form-control txt_OrderNo" style="width: 100px;" disabled value="@inTransactTrain.OrderNo" />
                                <input type="text" class="form-control txt_TrainID" style="width: 100px;" disabled value="@inTransactTrain.TrainID" />
                            </td>
                            <td>
                                <input class="form-control txt_ContainerNo" style="width: 150px;" type="text" disabled value="@inTransactTrain.ContainerNo" />
                            </td>
                            <td>
                                <input class="form-control txt_ContainerSize" style="width: 100px;" type="text" disabled value="@inTransactTrain.ContainerSize" />
                            </td>
                            <td>
                                <input class="form-control txt_ClientName" style="width: 170px;" type="text" disabled placeholder="" value="@(inTransactTrain.ClientName)" />
                            </td>
                            <td>
                                <select class="form-control txt_Priority" aria-invalid="false" style="width: 145px;">
                                    <option value="">Select Priority</option>
                                    <option value="1" @(inTransactTrain.PriorityForDispatched == "1" ? "selected=selected" : "")>1</option>
                                    <option value="2" @(inTransactTrain.PriorityForDispatched == "2" ? "selected=selected" : "")>2</option>
                                    <option value="3" @(inTransactTrain.PriorityForDispatched == "3" ? "selected=selected" : "")>3</option>
                                </select>
                            </td>
                            
                            <td>
                                <input class="date-picker form-control txt_ArrivalDateTime" style="width: 170px;" type="datetime" placeholder="" value="@(inTransactTrain.ArrivalDate.HasValue ? inTransactTrain.ArrivalDate.Value.ToString("yyyy-MM-dd") : "")" />
                            </td>
                            <td>
                                <input class=" form-control txt_lolo" style="width: 170px;" type="checkbox" placeholder="" value="@(inTransactTrain.LOLO)" />
                            </td>
                           
                            <td class="btn-group">
                                <button type="button" class="btn btn-sm btn-block btn-success btn-v2 fs-8 text-nowrap mt-1 mb-0 btnSave">Save</button>&ensp;
                                <button type="button" class="btn btn-sm btn-block btn-primary btn-v2 fs-8 text-nowrap mt-1 mb-0 btnIntransact">In-TransactTrain</button>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <!-- LOADING SHOW HIDE -->
        <div class="loading-dimmer"><img src="~/AdminLte/dist/img/loading.gif" /></div>
    </div>
</div>
<script src="@Fingerprint.Tag("/AdminLte/Scripts/OrderBookings/InTransactTrain.js")"></script>
